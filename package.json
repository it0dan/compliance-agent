{
  "name": "compliance-agent",
  "version": "1.0.0",
  "description": "Agente especializado independente de compliance regulatório (KYC, PLD, LGPD) para o ecossistema de crédito.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "./run_all_evals.sh"
  },
  "keywords": [
    "compliance",
    "agentic",
    "fastify",
    "typescript",
    "zod"
  ],
  "author": "Danilo Amaral",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/supertest": "latest",
    "@vitest/coverage-v8": "latest",
    "supertest": "latest",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2",
    "vitest": "latest"
  }
}
